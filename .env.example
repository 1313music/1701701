# Video gate password for build-time fallback.
VITE_VIDEO_PASSWORD=SongSharing
VITE_VIDEO_ACCESS_CONFIG_URL=https://r2.1701701.xyz/json/video-access.json
# Optional: cache video password JSON in the browser session to avoid reading R2 on every video click.
# Default: 43200000 (12 hours). Set to 0 to disable the in-memory cache.
VITE_VIDEO_ACCESS_CONFIG_CACHE_TTL_MS=43200000

# Toggle comment nav item in sidebar/mobile menu (optional)
# false/empty: hide, true: show
VITE_SHOW_COMMENT_NAV=false

# Toggle public resource download page /download (optional)
# false/empty: hide, true: show
VITE_SHOW_DOWNLOAD_PAGE=false

# Toggle album mini-program QR codes for saving albums to NetEase Cloud Drive (optional)
# true/empty: show, false: hide
VITE_SHOW_MINI_PROGRAM_QR=true

# Umami Cloud analytics (optional)
# Defaults to the Umami Cloud website created for 1701701.xyz.
# Set VITE_UMAMI_WEBSITE_ID only if replacing the Umami website.
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
VITE_UMAMI_DOMAINS=1701701.xyz
VITE_UMAMI_HOST_URL=

# Gallery image index (optional)
# If empty, defaults to https://imgs.1701701.xyz/data/images.json
VITE_GALLERY_INDEX_URL=

# Announcement JSON (optional)
# Public static JSON used by normal visitors. If empty, defaults to /announcement.json.
# Example: https://notice.1701701.xyz/announcement.json
VITE_ANNOUNCEMENT_URL=

# Announcement backend API base URL for /admin only (optional)
# Example: https://1701701-announcement-admin.your-subdomain.workers.dev
VITE_ANNOUNCEMENT_API_BASE_URL=

# Shared backend API base URL for /admin tools (optional)
# If set, this is used before VITE_ANNOUNCEMENT_API_BASE_URL.
VITE_ADMIN_API_BASE_URL=

# Optional manifest override (if empty, defaults to R2 JSON index URLs)
# VITE_VIDEO_INDEX_URL=https://r2.1701701.xyz/json/video-index.json
# VITE_MUSIC_INDEX_URL=https://r2.1701701.xyz/json/music-index.json
# VITE_DOWNLOAD_INDEX_URL=https://r2.1701701.xyz/json/download-index.json

# Optional video access QR fallback.
VITE_VIDEO_ACCESS_QR_URL=https://r2.1701701.xyz/QR/v.jpg
VITE_VIDEO_INDEX_URL=
VITE_MUSIC_INDEX_URL=
VITE_DOWNLOAD_INDEX_URL=

# Optional video danmaku backend.
# Leave empty to disable danmaku. When enabled, point to the Worker route that
# serves DPlayer-compatible /v3/ endpoints.
# Example: https://1701701.xyz/api/danmaku
VITE_VIDEO_DANMAKU_API_URL=
VITE_VIDEO_DANMAKU_AUTHOR=1701701
VITE_VIDEO_DANMAKU_MAXIMUM=1000
VITE_VIDEO_DANMAKU_BOTTOM=12%
VITE_VIDEO_DANMAKU_SPEED_RATE=0.9
