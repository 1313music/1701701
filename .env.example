# Video gate password for build-time injection
VITE_VIDEO_PASSWORD=replace-with-your-password

# B2 gallery index (optional)
# If empty, defaults to https://images.1701701.xyz/gallery-index.json
VITE_GALLERY_INDEX_URL=

# Optional manifest override (if empty, defaults to R2 JSON index URLs)
# VITE_VIDEO_INDEX_URL=https://r2.1701701.xyz/json/video-index.json
# VITE_MUSIC_INDEX_URL=https://r2.1701701.xyz/json/music-index.json
# VITE_DOWNLOAD_INDEX_URL=https://r2.1701701.xyz/json/download-index.json
VITE_VIDEO_INDEX_URL=
VITE_MUSIC_INDEX_URL=
VITE_DOWNLOAD_INDEX_URL=
